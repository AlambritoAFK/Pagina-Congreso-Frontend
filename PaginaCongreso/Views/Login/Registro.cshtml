@model PaginaCongreso.Models.Persona

@{
    Layout = "~/Views/Shared/_LayoutLogin.cshtml"; //Para todo el Login tiene su propio Layout, es la página que comparte ciertos elementos para todas las vistas de Login
}
<div class="container bg-white p-5 rounded-4">
    <h2>Registrarse</h2>
    <form asp-action="Registro" method="post">
        <div class="form-group">
            <label asp-for="Carne"></label>
            <input asp-for="Carne" class="form-control" />
        </div>
        <div class="form-group mt-3">
            <label asp-for="Nombres"></label>
            <input asp-for="Nombres" class="form-control" />
        </div>
        <div class="form-group mt-3">
            <label asp-for="Apellidos"></label>
            <input asp-for="Apellidos" class="form-control" />
        </div>
        <div class="form-group mt-3">
            <label asp-for="Correo"></label>
            <input asp-for="Correo" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary mt-4">Registrarse</button>
    </form>
</div>
