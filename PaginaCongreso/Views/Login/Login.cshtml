@model PaginaCongreso.Models.Usuario

@{
    Layout = "~/Views/Shared/_LayoutLogin.cshtml"; //Para todo el Login tiene su propio Layout, es la página que comparte ciertos elementos para todas las vistas de Login
}
<div class="container bg-white p-5 rounded-4">
    <h2>
        Iniciar Sesión
    </h2>
    <form asp-action="Login" method="post">
        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" class="form-control" />
        </div>
        <div class="form-group mt-3">
            <label asp-for="Password"></label>
            <input asp-for="Password" class="form-control" type="password" />
        </div>
        <div class="mt-3 text-center text-primary">
            <a asp-controller="Login" asp-action="Autenticacion">¿Aún no tienes usuario? Regístrate aquí</a>
        </div>
        <button type="submit" class="btn btn-primary mt-4">Ingresar</button>
    </form>
</div>