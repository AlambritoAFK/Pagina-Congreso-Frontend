            <div class="row">
                <h2 class="fs-1">
                    Sobre el congreso
                </h2>
            </div>
            <div class="row">
                <p class="fs-5">
                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc vitae molestie justo. Praesent accumsan, purus sit amet tempus ornare, mi metus vehicula urna, vitae rhoncus sem dolor sit amet lacus. Pellentesque risus lacus, posuere nec ligula ut, faucibus viverra erat. Suspendisse non odio ipsum. Etiam a suscipit tellus. Pellentesque accumsan mauris quis lacinia dignissim.
                </p>
                <p class="fs-5">
                    Vestibulum eget malesuada tellus, a pellentesque nisl. Morbi neque ex, venenatis et risus in, mollis rhoncus ex. Praesent iaculis nisl ac dignissim efficitur. Sed vehicula et nisl vel egestas. Praesent ac arcu eu purus egestas tempor. Aliquam est metus, bibendum ultrices urna ac, consequat tristique eros.
                </p>
            </div>
        </div>
    </div>
</div>

<!--Division para cambiar de seccion-->

<div class="row position-relative bannerDivision text-white d-flex align-items-center justify-content-center">

    <!-- La imagen de fondo como tal-->
    <div class="position-absolute top-0 start-0 w-100 h-100 imagenDivision"></div>

    <!-- El color rojo de fondo y la opacidad-->
    <div class="position-absolute top-0 start-0 w-100 h-100 opacity-75" style="background-color:rgb(170, 26, 45)"></div>

    <!-- Texto central -->
    <div class="container-fluid p-4 text-center z-1 d-flex flex-column align-items-center justify-content-center h-100">
        <div class="row text-center fs-1 fw-bold">
            CONOCE NUESTRAS CONFERENCIAS
        </div>
        <div class="row text-center mb-3 lineaTitulo">
        </div>
        <div class="row text-center fs-4 fw-light">
            Espacios de aprendizaje orientados al aprendizaje
        </div>
    </div>
</div>

<!--Fechas de las conferencias-->

<div class="container mt-5">
    <div class="row">
        <div class="row mb-3">
            <h2>
                Ingeniería en Sistemas, Electrónica y Telecomunicaciones
            </h2>
        </div>
        <!--Inicia las cartas de las conferencias-->
       
        <div class="row mb-5">
            <div>
                <div class="d-flex flex-row overflow-auto">
                    @foreach (var conferencia in Model.ConferenciasSis)
                    {
                    <div class="card me-3 cartaSistemas text-white" style="max-width:400px; min-width:400px">
                        <div class="card-header fs-6">
                                @conferencia.fecha_Conferencia.ToString("dddd, dd 'de' MMMM 'de' yyyy 'a las' HH:mm")
                        </div>
                            <div class="card-body">
                                <h5 class="card-title fs-3 fw-bold">@conferencia.nombre_Conferencia</h5>
                                <p class="card-text">
                                    @conferencia.salon_Conferencia
                                </p>
                            </div>
                            <div class="card-footer">
                                @conferencia.Conferencista
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        
        <!--Termina las cartas de la conferencias-->
    </div>
    <div class="row">
        <div class="row mb-3">
            <h2>
                Ingeniería Industrial
            </h2>
        </div>
        <div class="row mb-5">
            <div>
                <div class="d-flex flex-row overflow-auto">
                    @foreach (var conferencia in Model.ConferenciasIndus)
                    {
                        <div class="card me-3 cartaIndustrial text-white" style="max-width:400px; min-width:400px">
                            <div class="card-header fs-6">
                                @conferencia.fecha_Conferencia.ToString("dddd, dd 'de' MMMM 'de' yyyy 'a las' HH:mm")
                            </div>
                            <div class="card-body">
                                <h5 class="card-title fs-3 fw-bold">@conferencia.nombre_Conferencia</h5>
                                <p class="card-text">
                                    @conferencia.salon_Conferencia
                                </p>
                            </div>
                            <div class="card-footer">
                                @conferencia.Conferencista
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="row mb-3">
            <h2>
                Facultad de Económicas
            </h2>
        </div>
        <div class="row mb-5">
            <div>
                <div class="d-flex flex-row overflow-auto">
                    @foreach (var conferencia in Model.ConferenciasEcono)
                    {
                        <div class="card me-3 cartaEconomicas text-white" style="max-width:400px; min-width:400px">
                            <div class="card-header fs-6">
