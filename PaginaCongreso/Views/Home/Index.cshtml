@model HomeIndexViewModel
@{
    Layout = "~/Views/Shared/_LayoutInformativo.cshtml"; //Para la página informativa existe su propio Layout, es la página que alberga el index.cshtml
}
<!--Esto es todo el div para la imagen del inicio-->
<div class="row position-relative bannerCongreso text-white d-flex align-items-center justify-content-center">

    <!-- El Navbar transparente -->
    <nav class="navbar navbar-expand-lg navbar-dark position-absolute top-0 start-0 w-100 z-2 px-4 px-md-5">
        <div class="container">
            <a class="navbar-brand" href="#">
                <img src="~/Imagenes/EmprendeTecLogo.png" alt="Emprendetec" width="195" height="32">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active elementoNav" aria-current="page" href="#">INICIO</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link elementoNav" href="#">SOBRE EL CONGRESO</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link elementoNav" href="#">HORARIOS</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link elementoNav" href="#">CONFERENCISTAS</a>
                    </li>              
                </ul>
                <a asp-controller="Login" asp-action="Login" class="btn botonInicio">
                    Ingresar
                </a>
            </div>
        </div>
    </nav>

    <!-- La imagen de fondo como tal-->
    <div class="position-absolute top-0 start-0 w-100 h-100 imagenFondo"></div>

    <!-- El color rojo de fondo y la opacidad-->
    <div class="position-absolute top-0 start-0 w-100 h-100 opacity-75" style="background-color:rgb(170, 26, 45)"></div>

    <!-- Texto central -->
    <div class="container-fluid p-4 text-center z-1 d-flex flex-column align-items-center justify-content-center h-100">
        <div class="row text-center fs-4 mb-3">
            Un espacio para aprender
        </div>
        <div class="row text-center fs-1 fw-bold">
            CONGRESO EMPRENDETEC
        </div>
        <div class="row text-center mb-3 lineaTitulo">
        </div>
        <div class="row text-center fs-4 fw-light">
            Para mentes creativas, técnicas y visionarias.
        </div>
        <div class="row text-center fs-4 fw-light">
            Una experiencia que conecta tecnología, innovación y emprendimiento.
        </div>
    </div>
</div>

<!--Fecha y Lugar-->
<div class="container-fluid">
    <div class="row">
        <div class="col-md-6 ladoIzquierdo p-4">
            <div class="row justify-content-md-end justify-content-center text-center align-items-center">
                <div class="col-md-6 text-black fondoIcono my-2 justify-content-center align-content-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="90" height="90" fill="currentColor" class="bi bi-calendar-event-fill" viewBox="0 0 16 16">
                        <path d="M4 .5a.5.5 0 0 0-1 0V1H2a2 2 0 0 0-2 2v1h16V3a2 2 0 0 0-2-2h-1V.5a.5.5 0 0 0-1 0V1H4zM16 14V5H0v9a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2m-3.5-7h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5" />
                    </svg>
                </div>
                <div class="col-md-6 text-white text-center">
                    <div class="row">
                        <h3 class="text-center fs-3">
                            Cuando
                        </h3>
                    </div>
                    <div class="row fs-2 fw-bold">
                        <h2>
                            2-4 OCTUBRE 2025
                        </h2>
                    </div>
                    <div class="row">
                        <h4 class="text-center  fs-4 fw-lighter">
                            Primer día virtual, 3 y 4 presencial.
                        </h4>

                    </div>
                </div>
