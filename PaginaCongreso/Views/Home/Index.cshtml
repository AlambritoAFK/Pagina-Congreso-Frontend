        </div>
        <div class="col-md-6 ladoDerecho p-4">
            <div class="row justify-content-md-start justify-content-center text-center align-items-center">
                <div class="col-md-6 text-white text-center">
                    <div class="row">
                        <h3 class="text-center fs-3">
                            Donde
                        </h3>
                    </div>
                    <div class="row fs-2 fw-bold">
                        <h2>
                            Centro de Convenciones Gran Karmel
                        </h2>
                    </div>
                    <div class="row">
                        <h4 class="text-center  fs-4 fw-lighter">
                            En el salón imperial.
                        </h4>

                    </div>
