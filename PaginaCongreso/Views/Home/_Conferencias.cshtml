                                </p>
                            </div>
                            <div class="card-footer">
                                @conferencia.Conferencista
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!--Termina las cartas de la conferencias de Ingeniería Industrial-->

    </div>
    <div class="row">
        <div class="row mb-3">
            <h2>
                Facultad de Económicas
            </h2>
        </div>

        <!--Inicia las cartas de las conferencias de Económicas-->

